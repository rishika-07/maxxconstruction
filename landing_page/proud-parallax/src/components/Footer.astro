---
import { navLinks, site } from '../data/site';
---

<footer class="site-footer">
  <div class="container footer-grid">
    <section>
      <p class="label">MAXX CONSTRUCTION GROUP</p>
      <p class="muted">BUILDING DREAMS, CREATING LEGACIES.</p>
      <p><a href={site.tel}>{site.phone}</a></p>
      <p><a href={`mailto:${site.email}`}>{site.email}</a></p>
      <p class="muted">{site.address}</p>
    </section>

    <section>
      <p class="label">NAVIGATION</p>
      <ul class="footer-links">
        {navLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </section>

    <section>
      <p class="label">FOLLOW US</p>
      <ul class="footer-links">
        {site.socials.map((social) => (
          <li><a href={social.href} rel="noreferrer" target="_blank">{social.label}</a></li>
        ))}
      </ul>
    </section>
  </div>

  <div class="footer-base container">
    <p>Copyright {new Date().getFullYear()} Maxx Construction Group. All rights reserved.</p>
  </div>
</footer>
