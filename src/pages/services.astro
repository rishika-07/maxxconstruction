---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Services | Maxx Construction Group" description="New builds, renovations, duplex and townhouse projects, and commercial fitouts.">
  <section class="section">
    <div class="container">
      <p class="kicker">WHAT WE DO</p>
      <h1 class="section-title">CONSTRUCTION SERVICES</h1>
      <p class="section-intro">
        End-to-end delivery from planning support and budget alignment to build
        execution and quality-assured handover.
      </p>
    </div>
  </section>

  <section class="section section-surface">
    <div class="container grid-2">
      {services.map((service) => (
        <article class="card">
          <p class="label">{service.data.icon}</p>
          <h2>{service.data.title}</h2>
          <p>{service.data.excerpt}</p>
          <a class="text-link" href={`${import.meta.env.BASE_URL}contact`}>REQUEST ESTIMATE</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="kicker">PROJECT FLOW</p>
      <h2 class="section-title">OUR BUILD PROCESS</h2>
      <div class="grid-4">
        <article class="card"><h3>01 DISCOVERY</h3><p>Site review, scope alignment, and budget framing.</p></article>
        <article class="card"><h3>02 PRE-CONSTRUCTION</h3><p>Program definition, procurement planning, and permits coordination.</p></article>
        <article class="card"><h3>03 CONSTRUCTION</h3><p>Disciplined execution with quality and safety checkpoints.</p></article>
        <article class="card"><h3>04 HANDOVER</h3><p>Final inspections, defect closeout, and documentation pack.</p></article>
      </div>
    </div>
  </section>
</BaseLayout>
