---
import { navLinks, site } from '../data/site';
---

<header class="site-header">
  <div class="header-shell container">
    <details class="menu-drawer">
      <summary aria-label="Open site navigation">
        <span class="menu-icon" aria-hidden="true"></span>
        <span>MENU</span>
      </summary>
      <nav class="drawer-panel" aria-label="Main navigation">
        <ul>
          {navLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </nav>
    </details>

    <a class="brand-mark" href="/" aria-label="Maxx Construction Group homepage">
      MAXX CONSTRUCTION GROUP
    </a>

    <div class="header-actions">
      <details class="search-drawer">
        <summary aria-label="Open quick search">SEARCH</summary>
        <div class="search-drawer-panel">
          <label class="sr-only" for="header-search-input">Search</label>
          <input id="header-search-input" type="search" placeholder="Search projects or services" />
          <button type="button">GO</button>
          <a href="/search" aria-label="Open full search page">OPEN SEARCH PAGE</a>
        </div>
      </details>
      <a href="/projects" aria-label="Go to projects page">BOOKMARK</a>
    </div>
  </div>

  <div class="header-contact-bar">
    <p>
      CONTACT SUPPORT:
      <a href={site.tel}>{site.phone}</a>
      | EMAIL SUPPORT:
      <a href={`mailto:${site.email}`}>{site.email}</a>
    </p>
  </div>
</header>
