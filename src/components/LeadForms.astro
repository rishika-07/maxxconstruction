---

<section class="section section-surface" id="lead-forms">
  <div class="container">
    <p class="kicker" data-reveal>CONTACT US</p>
    <h2 class="section-title" data-reveal>START YOUR PROJECT CONVERSATION</h2>
    <p class="section-intro" data-reveal>
      Choose a pathway below. These forms are launch-ready templates and can be connected
      to your preferred CRM or email webhook in minutes.
    </p>

    <div class="lead-grid" data-stagger>
      <form class="lead-form" method="post" action="#" aria-label="Quick quote form" data-gsap-card>
        <h3>QUICK QUOTE</h3>
        <label>
          FULL NAME
          <input name="name" autocomplete="name" required />
        </label>
        <label>
          EMAIL
          <input name="email" type="email" autocomplete="email" required />
        </label>
        <label>
          PROJECT TYPE
          <select name="projectType" required>
            <option value="">Select one</option>
            <option>New Build</option>
            <option>Renovation</option>
            <option>Duplex / Townhouse</option>
            <option>Commercial Fitout</option>
          </select>
        </label>
        <p class="form-feedback" aria-live="polite"></p>
        <button type="submit" class="btn-accent">SUBMIT QUOTE REQUEST</button>
      </form>

      <form class="lead-form" method="post" action="#" aria-label="Site visit form" data-gsap-card>
        <h3>BOOK SITE VISIT</h3>
        <label>
          FULL NAME
          <input name="name" autocomplete="name" required />
        </label>
        <label>
          PHONE
          <input name="phone" type="tel" autocomplete="tel" required />
        </label>
        <label>
          PREFERRED DATE
          <input name="date" type="date" required />
        </label>
        <p class="form-feedback" aria-live="polite"></p>
        <button type="submit" class="btn-accent">REQUEST SITE VISIT</button>
      </form>

      <form class="lead-form" method="post" action="#" aria-label="Call back form" data-gsap-card>
        <h3>CALL-BACK REQUEST</h3>
        <label>
          FULL NAME
          <input name="name" autocomplete="name" required />
        </label>
        <label>
          PHONE
          <input name="phone" type="tel" autocomplete="tel" required />
        </label>
        <label>
          BEST TIME TO CALL
          <input name="callWindow" placeholder="e.g. Weekdays 3pm to 6pm" required />
        </label>
        <p class="form-feedback" aria-live="polite"></p>
        <button type="submit" class="btn-accent">REQUEST CALL-BACK</button>
      </form>
    </div>
  </div>
</section>
