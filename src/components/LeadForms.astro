---

<section class="section section-surface" id="lead-forms">
  <div class="container">
    <p class="kicker">CONTACT US</p>
    <h2 class="section-title">START YOUR PROJECT CONVERSATION</h2>
    <p class="section-intro">
      Choose a pathway below. These forms are launch-ready templates and can be connected
      to your preferred CRM or email webhook in minutes.
    </p>

    <div class="lead-grid">
      <form class="lead-form" method="post" action="#" aria-label="Quick quote form">
        <h3>QUICK QUOTE</h3>
        <label>
          FULL NAME
          <input name="name" autocomplete="name" required />
        </label>
        <label>
          EMAIL
          <input name="email" type="email" autocomplete="email" required />
        </label>
        <label>
          PROJECT TYPE
          <select name="projectType" required>
            <option value="">Select one</option>
            <option>New Build</option>
            <option>Renovation</option>
            <option>Duplex / Townhouse</option>
            <option>Commercial Fitout</option>
          </select>
        </label>
        <button type="submit" class="btn-accent">SUBMIT QUOTE REQUEST</button>
      </form>

      <form class="lead-form" method="post" action="#" aria-label="Site visit form">
        <h3>BOOK SITE VISIT</h3>
        <label>
          FULL NAME
          <input name="name" autocomplete="name" required />
        </label>
        <label>
          PHONE
          <input name="phone" type="tel" autocomplete="tel" required />
        </label>
        <label>
          PREFERRED DATE
          <input name="date" type="date" required />
        </label>
        <button type="submit" class="btn-accent">REQUEST SITE VISIT</button>
      </form>

      <form class="lead-form" method="post" action="#" aria-label="Call back form">
        <h3>CALL-BACK REQUEST</h3>
        <label>
          FULL NAME
          <input name="name" autocomplete="name" required />
        </label>
        <label>
          PHONE
          <input name="phone" type="tel" autocomplete="tel" required />
        </label>
        <label>
          BEST TIME TO CALL
          <input name="callWindow" placeholder="e.g. Weekdays 3pm to 6pm" required />
        </label>
        <button type="submit" class="btn-accent">REQUEST CALL-BACK</button>
      </form>
    </div>
  </div>
</section>
